# Copy to .env and fill in production values
# docker compose automatically reads .env

# PostgreSQL
POSTGRES_DB=quant_trading
POSTGRES_USER=quant
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Application
DATABASE_URL=postgresql://quant:CHANGE_ME_TO_A_STRONG_PASSWORD@postgres:5432/quant_trading
API_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
CORS_ORIGINS=https://your-domain.com
RUST_LOG=quant=info

# Data providers
TUSHARE_TOKEN=
GITHUB_TOKEN=
